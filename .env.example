# ===========================================
# Jan Sahayak - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Sarvam AI API Key (get from https://dashboard.sarvam.ai/)
SARVAM_API_KEY=your_sarvam_api_key_here

# LiveKit Configuration
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# Database (SQLite for now, PostgreSQL later)
DATABASE_URL=sqlite+aiosqlite:///./jan_sahayak.db

# Application Settings
APP_NAME=Jan Sahayak
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS (allowed origins for frontend)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LangSmith Observability
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=jan-sahayak
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Authentication & JWT
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_EXPIRY_MINUTES=1440
AUTH_PROVIDER=local
FIREBASE_CREDENTIALS_PATH=jansahayak-firebase-credentials.json

